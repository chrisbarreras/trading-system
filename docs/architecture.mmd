---
config:
  theme: neutral
  themeVariables:
    fontFamily: "Inter, Helvetica, Arial, sans-serif"
    fontSize: "15px"
  flowchart:
    nodeSpacing: 50
    rankSpacing: 70
    curve: basis
    padding: 20
---
graph LR
    classDef ctrl fill:#1e293b,stroke:#0f172a,color:#f8fafc,stroke-width:2px
    classDef acct fill:#0ea5e9,stroke:#0369a1,color:#ffffff,stroke-width:2px
    classDef pipe fill:#10b981,stroke:#047857,color:#ffffff,stroke-width:2px
    classDef ext fill:#f59e0b,stroke:#b45309,color:#ffffff,stroke-width:2px
    classDef bt fill:#a855f7,stroke:#7e22ce,color:#ffffff,stroke-width:2px
    classDef store fill:#475569,stroke:#1e293b,color:#f8fafc,stroke-width:2px

    subgraph cp["Control Plane"]
        API["FastAPI Server<br/>webhooks · status · health"]
        ORCH["Orchestrator<br/>schedule + ET timezone"]
    end

    subgraph runners["Multi-Account Runners"]
        A1["Swing RSI<br/>daily · 09:35 ET"]
        A2["Day MACD<br/>15m · every 15min"]
        A3["Swing Combo<br/>daily · 09:35 ET"]
    end

    subgraph pl["Trading Pipeline"]
        SCAN["Scanner<br/>Strategy Registry"]
        EXEC["Trade Executor<br/>risk · position sizing"]
    end

    DATA["Yahoo · Alpaca<br/>Market Data"]
    BROKER["Alpaca<br/>Brokerage"]
    DB[("SQLite<br/>signals · trades")]
    BT["Backtest Engine<br/>walk-forward · no lookahead"]

    API --> ORCH
    ORCH --> A1
    ORCH --> A2
    ORCH --> A3
    A1 --> SCAN
    A2 --> SCAN
    A3 --> SCAN
    DATA --> SCAN
    SCAN --> EXEC
    EXEC --> BROKER
    EXEC --> DB
    BT -.historical.-> DATA
    BT --> DB

    class API,ORCH ctrl
    class A1,A2,A3 acct
    class SCAN,EXEC pipe
    class DATA,BROKER ext
    class DB store
    class BT bt

    style cp fill:#f8fafc,stroke:#e2e8f0,stroke-width:1px,color:#475569
    style runners fill:#f8fafc,stroke:#e2e8f0,stroke-width:1px,color:#475569
    style pl fill:#f8fafc,stroke:#e2e8f0,stroke-width:1px,color:#475569
