# Trading Mode (paper or live)
TRADING_MODE=paper

# Alpaca API Credentials
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Database
DATABASE_URL=sqlite:///./trading_paper.db

# TradingView Webhook Security
# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret_here

# Risk Management Parameters
MAX_POSITIONS=5
POSITION_SIZE_PCT=0.10
MAX_DAILY_TRADES=20
MAX_POSITION_SIZE_USD=10000

# Advanced Position Sizing
# Minimum buying power to allow any trades (reduced from $1,000 to $100)
MIN_BUYING_POWER=100.0
# Minimum dollar value per trade to avoid tiny uneconomical trades
MIN_TRADE_SIZE_USD=50.0
# Position sizing mode: adaptive (recommended), portfolio (old behavior), or buying_power (aggressive)
POSITION_SIZING_MODE=adaptive
# Percentage of buying power to keep in reserve for fees/slippage
BUYING_POWER_RESERVE_PCT=0.05

# Extended Hours Trading (pre-market 4AM + after-hours 8PM ET, uses limit orders)
EXTENDED_HOURS_ENABLED=false

# Logging
LOG_LEVEL=DEBUG

# Stock List Auto-Update
# How often to update stock lists (in days) - default is weekly
STOCK_LIST_UPDATE_DAYS=7
# Set to true to enable automatic updates when using --symbols-file
AUTO_UPDATE_STOCK_LIST=true

# Order Management
# Automatically cancel orders older than this many hours (prevents stuck orders from tying up buying power)
AUTO_CANCEL_ORDER_AGE_HOURS=1
# Enable automatic cleanup of stale orders on scanner startup
AUTO_CLEANUP_ORDERS=true
